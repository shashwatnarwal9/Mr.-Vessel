# Copy to .env and fill. .env is gitignored — never commit real keys.
#
# EVERY key is optional. Each external client sits behind an interface with a
# baked-data fallback, so the full app runs with zero keys and no internet —
# features just label themselves as snapshot instead of live.

# ---- data feeds -------------------------------------------------------------
AIS_API_KEY=              # aisstream.io — live tanker positions (WebSocket)
NVIDIA_API_KEY=           # build.nvidia.com — GLM-5.2 tagging/narration + bge-m3
CUOPT_API_KEY=            # NVIDIA cuOpt — independent check of ship-detour routing
FUEL_PRICE_API_KEY=       # fuel.indianapi.in — live Delhi pump price (1h cache)

# ---- news (Signals rail + the live corridor-risk news signal) ----------------
# Google News is primary and India-positioned; the Guardian backfills a 7-day
# window so the rail can scroll back a week immediately. GDELT needs no key.
GOOGLE_NEWS_API_KEY=      # RapidAPI (google-news13)
GUARDIAN_API_KEY=         # open-platform.theguardian.com (free)

# ---- War Cabinet: one NVIDIA-hosted model per minister ----------------------
# Model ids have code defaults; override only if a catalog string differs.
# NVIDIA keys are often per-model, so each role can carry its own; any blank
# *_API_KEY falls back to NVIDIA_API_KEY.
FM_MODEL=                 # Foreign Minister (default: the shared chat model)
DM_MODEL=                 # Defence Minister (default: qwen/qwen3.5-122b-a10b)
PM_MODEL=                 # Prime Minister   (default: mistral-large-3)
FM_API_KEY=
DM_API_KEY=
PM_API_KEY=

# ---- server -----------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173

# ---- knowledge graph (optional; identical Python BFS fallback when absent) ---
# docker run -d --name vessel-neo4j -p 7474:7474 -p 7687:7687 \
#   -e NEO4J_AUTH=neo4j/vesselpass neo4j:5
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=vesselpass

# ---- frontend (build-time; put these in frontend/.env) ----------------------
# Vite inlines them at BUILD time — a wrong URL fails as a silent CORS error.
# VITE_API_HTTP=http://localhost:8000
# VITE_API_WS=ws://localhost:8000
